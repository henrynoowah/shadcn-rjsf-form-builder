{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "shadcn-rjsf-form-builder",
  "homepage": "https://github.com/henrycho/shadcn-rjsf-form-builder",
  "items": [
    {
      "name": "form-builder-types",
      "type": "registry:lib",
      "title": "Form Builder Types",
      "description": "Type definitions and utilities for the RJSF form builder: schema conversion, i18n, and validation.",
      "dependencies": ["@rjsf/utils", "@rjsf/validator-ajv8"],
      "files": [
        { "path": "registry/form-builder-types/types.ts", "type": "registry:lib", "target": "lib/form-builder-types/types.ts" },
        { "path": "registry/form-builder-types/i18n.ts", "type": "registry:lib", "target": "lib/form-builder-types/i18n.ts" },
        { "path": "registry/form-builder-types/schema-builder.ts", "type": "registry:lib", "target": "lib/form-builder-types/schema-builder.ts" },
        { "path": "registry/form-builder-types/validation.ts", "type": "registry:lib", "target": "lib/form-builder-types/validation.ts" }
      ]
    },
    {
      "name": "form-renderer",
      "type": "registry:ui",
      "title": "Form Renderer",
      "description": "A themed RJSF form renderer with shadcn/ui-styled widgets, fields, and templates.",
      "dependencies": ["@rjsf/core", "@rjsf/utils", "@rjsf/validator-ajv8", "radix-ui", "@tabler/icons-react", "clsx", "tailwind-merge"],
      "registryDependencies": ["form-builder-types"],
      "files": [
        { "path": "registry/form-renderer/form-renderer.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/form-renderer.tsx" },
        { "path": "registry/form-renderer/theme.ts", "type": "registry:ui", "target": "components/ui/form-renderer/theme.ts" },
        { "path": "registry/form-renderer/widgets/text-widget.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/widgets/text-widget.tsx" },
        { "path": "registry/form-renderer/widgets/textarea-widget.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/widgets/textarea-widget.tsx" },
        { "path": "registry/form-renderer/widgets/select-widget.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/widgets/select-widget.tsx" },
        { "path": "registry/form-renderer/widgets/checkbox-widget.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/widgets/checkbox-widget.tsx" },
        { "path": "registry/form-renderer/widgets/radio-widget.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/widgets/radio-widget.tsx" },
        { "path": "registry/form-renderer/widgets/date-widget.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/widgets/date-widget.tsx" },
        { "path": "registry/form-renderer/widgets/file-widget.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/widgets/file-widget.tsx" },
        { "path": "registry/form-renderer/fields/heading-field.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/fields/heading-field.tsx" },
        { "path": "registry/form-renderer/fields/paragraph-field.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/fields/paragraph-field.tsx" },
        { "path": "registry/form-renderer/fields/separator-field.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/fields/separator-field.tsx" },
        { "path": "registry/form-renderer/templates/field-template.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/templates/field-template.tsx" },
        { "path": "registry/form-renderer/templates/object-template.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/templates/object-template.tsx" },
        { "path": "registry/form-renderer/templates/array-template.tsx", "type": "registry:ui", "target": "components/ui/form-renderer/templates/array-template.tsx" }
      ]
    },
    {
      "name": "form-builder",
      "type": "registry:ui",
      "title": "Form Builder",
      "description": "A visual drag-and-drop form builder with field palette, canvas, and settings panel.",
      "dependencies": ["@dnd-kit/core", "@dnd-kit/sortable", "@dnd-kit/utilities", "nanoid", "@tabler/icons-react"],
      "registryDependencies": ["form-builder-types", "form-renderer"],
      "files": [
        { "path": "registry/form-builder/form-builder.tsx", "type": "registry:ui", "target": "components/ui/form-builder/form-builder.tsx" },
        { "path": "registry/form-builder/builder-context.tsx", "type": "registry:ui", "target": "components/ui/form-builder/builder-context.tsx" },
        { "path": "registry/form-builder/canvas.tsx", "type": "registry:ui", "target": "components/ui/form-builder/canvas.tsx" },
        { "path": "registry/form-builder/canvas-field.tsx", "type": "registry:ui", "target": "components/ui/form-builder/canvas-field.tsx" },
        { "path": "registry/form-builder/field-palette.tsx", "type": "registry:ui", "target": "components/ui/form-builder/field-palette.tsx" },
        { "path": "registry/form-builder/field-settings-panel.tsx", "type": "registry:ui", "target": "components/ui/form-builder/field-settings-panel.tsx" }
      ]
    }
  ]
}
